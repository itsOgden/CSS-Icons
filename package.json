{
  "name": "@itsogden/css-icons",
  "version": "1.0.0",
  "description": "SVG-to-CSS icon generator with Vue 3 / Nuxt 3+ component",
  "type": "module",
  "bin": {
    "css-icons": "./index.mjs"
  },
  "exports": {
    "./nuxt": {
      "types": "./nuxt.d.ts",
      "import": "./nuxt.mjs"
    },
    "./vite": {
      "types": "./vite.d.ts",
      "import": "./vite.mjs"
    }
  },
  "files": [
    "index.mjs",
    "generate.mjs",
    "nuxt.mjs",
    "nuxt.d.ts",
    "vite.mjs",
    "vite.d.ts"
  ],
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "keywords": ["icons", "svg", "css", "vue", "nuxt", "vite"],
  "author": "itsOgden",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}
